NODE_ENV=production
PORT=5000

# 推荐方式：直接使用标准 PostgreSQL 连接串
DATABASE_URL=postgres://postgres:password@host:5432/postgres

# 可选：如果你不用 DATABASE_URL，也可以分别填写下面这些变量
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=password

# 云数据库常见需要开启 SSL
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

DB_POOL_MAX=10

JWT_SECRET=please-change-this-secret
TOKEN_EXPIRES_IN_HOURS=24

# 多个来源用逗号分隔；生产环境请填写前端域名
CORS_ORIGIN=https://dangjian-really.vercel.app

LOG_LEVEL=info

# 可选：对外公开访问地址，用于拼接下载链接
# PUBLIC_APP_URL=https://your-backend.up.railway.app
