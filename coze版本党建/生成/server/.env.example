PORT=9091

# 推荐方式：直接使用标准 PostgreSQL 连接串
DATABASE_URL=postgres://postgres:password@host:5432/postgres

# 可选：如果你不用 DATABASE_URL，也可以分别填写下面这些变量
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=password

# 云数据库常见需要开启 SSL
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# 可选：自定义存储整站 JSON 数据的表名
DB_STORE_TABLE=party_app_store
